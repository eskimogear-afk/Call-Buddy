# DSCR Florida Lead Machine — environment variables
# Copy to .env (local) or set these in the Vercel project dashboard.
# NEVER commit real secrets.

# --- Supabase (server-side writes via service role) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Twilio (instant "speed to lead" text) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX        # the "from" number (must be off trial)

# Where the 🔥 new-lead text is sent. Defaults to +17542566781 if unset.
LEAD_NOTIFY_PHONE=+17542566781

# --- RentCast (rent estimate in the calculator; free tier = 50 calls/mo) ---
# If unset, the calculator falls back to manual rent entry automatically.
RENTCAST_API_KEY=your-rentcast-api-key

# --- Meta Conversions API (Facebook/Instagram ads) ---
# Server-side "Lead" event for better attribution (survives iOS/ad-blockers),
# deduplicated with the browser Pixel. If unset, /api/lead skips it silently.
# META_PIXEL_ID must match the Pixel ID you put in config.js (metaPixel).
# Get the token in Events Manager → your Pixel → Settings → Conversions API.
META_PIXEL_ID=
META_CONVERSIONS_TOKEN=

# --- Front-end IDs (these live in index.html, not here) ---
# GA4_MEASUREMENT_ID, PLAUSIBLE_DOMAIN, META_PIXEL_ID, GSC_VERIFICATION_TOKEN,
# displayed phone number, and company NMLS are edited directly in index.html /
# styles markup. Search index.html for "TODO" to find each one.
